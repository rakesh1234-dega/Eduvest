# ─── Supabase Keys ───
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key

# ─── Clerk Authentication Keys ───
# For LOCAL development, use the development key: pk_test_xxxxxxx
# For PRODUCTION deployments (Vercel, Netlify), use the live key: pk_live_xxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# ⚠️ SECURITY WARNING: 
# NEVER put your Clerk Secret Key (sk_test_ or sk_live_) in any VITE_ variable!
# Secret keys should only be used in a secure backend server environment.

# ─── Other ───
VITE_APP_URL=http://localhost:8080
VITE_GEMINI_API_KEY=your_gemini_api_key
